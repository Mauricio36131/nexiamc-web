---

<Layout lang={lang} title={titleMap[lang]} description={t.footer.tagline}>

<!-- ══════════ NAVBAR ══════════ -->
<nav class="fixed top-0 w-full z-50 bg-[#030712]/80 navbar-blur border-b border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <a href={langPaths[lang]} class="flex items-center gap-2.5 group">
        <div class="w-10 h-10 flex-shrink-0 group-hover:scale-110 transition-transform drop-shadow-[0_0_12px_rgba(59,130,246,0.6)]">
          <svg viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
            <rect width="44" height="44" rx="10" fill="url(#nb1)"/>
            <rect x="0.5" y="0.5" width="43" height="43" rx="9.5" stroke="url(#nb2)" stroke-width="1"/>
            <path d="M9 34V10h6l11 16V10h9v24h-6L18 18v16H9z" fill="white"/>
            <line x1="32" y1="2" x2="43" y2="13" stroke="#38bdf8" stroke-width="1.5" opacity="0.7"/>
            <line x1="0" y1="42" x2="44" y2="42" stroke="#3b82f6" stroke-width="1" opacity="0.5"/>
            <defs>
              <linearGradient id="nb1" x1="0" y1="0" x2="44" y2="44" gradientUnits="userSpaceOnUse">
                <stop stop-color="#0b1a38"/>
                <stop offset="1" stop-color="#071020"/>
              </linearGradient>
              <linearGradient id="nb2" x1="0" y1="0" x2="44" y2="44" gradientUnits="userSpaceOnUse">
                <stop stop-color="#3b82f6"/>
                <stop offset="1" stop-color="#06b6d4"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <span class="text-xl font-black text-white tracking-tight">NEXIA<span class="text-blue-400">MC</span></span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        {(['services','howItWorks','pricing','contact'] as const).map(key => (
          <a href={key === 'services' ? '#services' : key === 'howItWorks' ? '#how' : key === 'pricing' ? '#pricing' : '#contact'}
             class="text-slate-400 hover:text-white transition-colors text-sm font-medium relative group">
            {t.nav[key]}
            <span class="absolute -bottom-0.5 left-0 w-0 h-px bg-gradient-to-r from-blue-400 to-cyan-400 group-hover:w-full transition-all duration-300"></span>
          </a>
        ))}
      </div>

      <div class="flex items-center gap-3">
        <div class="relative group">
          <button class="text-slate-400 hover:text-white text-xs px-3 py-1.5 rounded-lg border border-slate-700/60 hover:border-blue-500/50 transition-all flex items-center gap-1.5 font-medium">
            {langLabels[lang]}
            <svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
