---
import Layout from '../layouts/Layout.astro';
import { translations, type Lang } from '../i18n/translations';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = translations[lang];

const langLabels: Record<Lang, string> = {
  es: '🇪🇸 ES', en: '🇺🇸 EN', de: '🇩🇪 DE', pt: '🇧🇷 PT', uk: '🇺🇦 UK'
};
const langNames: Record<Lang, string> = {
  es: 'Español', en: 'English', de: 'Deutsch', pt: 'Português', uk: 'Українська'
};
const langPaths: Record<Lang, string> = {
  es: '/', en: '/en', de: '/de', pt: '/pt', uk: '/uk'
};
const allLangs = ['es', 'en', 'de', 'pt', 'uk'] as Lang[];
const titleMap: Record<Lang, string> = {
  es: 'NexiaMC — Automatización IA para tu negocio',
  en: 'NexiaMC — AI Automation for your business',
  de: 'NexiaMC — KI-Automatisierung für Ihr Unternehmen',
  pt: 'NexiaMC — Automação IA para o seu negócio',
  uk: 'NexiaMC — ШІ-автоматизація для вашого бізнесу'
};

const iconColors = ['icon-blue','icon-cyan','icon-purple','icon-green','icon-orange','icon-teal','icon-pink','icon-red','icon-blue','icon-cyan','icon-purple','icon-green'];
---

<Layout lang={lang} title={titleMap[lang]} description={t.footer.tagline}>

<!-- ══════════ NAVBAR ══════════ -->
<nav class="fixed top-0 w-full z-50 bg-[#030712]/80 navbar-blur border-b border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <a href={langPaths[lang]} class="flex items-center gap-2.5 group">
        <div class="w-9 h-9 rounded-xl gradient-border bg-gradient-to-br from-blue-600 to-cyan-500 flex items-center justify-center text-white font-black text-base group-hover:scale-110 transition-transform shadow-lg shadow-blue-500/30">N</div>
        <span class="text-xl font-black text-white tracking-tight">Nexia<span class="text-blue-400">MC</span></span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        {(['services','howItWorks','pricing','contact'] as const).map(key => (
          <a href={key === 'services' ? '#services' : key === 'howItWorks' ? '#how' : key === 'pricing' ? '#pricing' : '#contact'}
             class="text-slate-400 hover:text-white transition-colors text-sm font-medium relative group">
            {t.nav[key]}
            <span class="absolute -bottom-0.5 left-0 w-0 h-px bg-gradient-to-r from-blue-400 to-cyan-400 group-hover:w-full transition-all duration-300"></span>
          </a>
        ))}
      </div>

      <div class="flex items-center gap-3">
        <div class="relative group">
          <button class="text-slate-400 hover:text-white text-xs px-3 py-1.5 rounded-lg border border-slate-700/60 hover:border-blue-500/50 transition-all flex items-center gap-1.5 font-medium">
            {langLabels[lang]}
            <svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="absolute right-0 mt-2 w-40 bg-[#0a1020] border border-slate-700/60 rounded-xl py-1.5 shadow-2xl shadow-black/60 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0">
            {allLangs.map(l => (
              <a href={langPaths[l]} class={`block px-4 py-2 text-sm transition-colors ${l === lang ? 'text-blue-400 font-bold' : 'text-slate-400 hover:text-white hover:bg-white/5'}`}>
                {langLabels[l]} {langNames[l]}
              </a>
            ))}
          </div>
        </div>
        <a href="#contact" class="btn-shimmer text-white text-sm px-5 py-2.5 rounded-xl font-bold hidden sm:block shadow-lg shadow-blue-500/20">
          {t.nav.cta}
        </a>
      </div>

    </div>
  </div>
</nav>


<!-- ══════════ HERO ══════════ -->
<section class="relative min-h-screen flex items-center overflow-hidden pt-16 animated-gradient">

  <!-- Hero background overlay -->
  <div class="absolute inset-0 z-0 bg-gradient-to-b from-transparent via-[#030712]/20 to-[#030712]/80"></div>

  <!-- Particle canvas -->
  <canvas id="particles" class="absolute inset-0 w-full h-full z-[1]"></canvas>

  <!-- Grid -->
  <div class="absolute inset-0 grid-bg opacity-40 z-[1]"></div>

  <!-- Blobs -->
  <div class="blob w-[700px] h-[700px] bg-blue-600/20 -top-32 -left-32 z-[1]"></div>
  <div class="blob blob-2 w-[500px] h-[500px] bg-purple-600/15 bottom-0 right-0"></div>
  <div class="blob blob-3 w-[400px] h-[400px] bg-cyan-500/15 top-1/2 right-1/4"></div>

  <!-- Spinning rings -->
  <div class="absolute right-10 top-1/3 w-72 h-72 rounded-full border border-blue-500/15 spin-slow hidden lg:block"></div>
  <div class="absolute right-20 top-1/3 w-52 h-52 rounded-full border border-cyan-500/10 hidden lg:block" style="animation: spin-slow 14s linear infinite reverse;"></div>
  <div class="absolute right-32 top-1/3 w-32 h-32 rounded-full border border-purple-500/10 hidden lg:block" style="animation: spin-slow 8s linear infinite;"></div>

  <!-- Floating orbs -->
  <div class="orb absolute top-1/3 right-10 w-3 h-3 bg-blue-400 rounded-full opacity-80 hidden lg:block shadow-lg shadow-blue-400/50"></div>
  <div class="orb orb-2 absolute top-1/2 right-28 w-2 h-2 bg-cyan-400 rounded-full opacity-60 hidden lg:block"></div>
  <div class="orb orb-3 absolute top-2/3 right-8 w-1.5 h-1.5 bg-purple-400 rounded-full opacity-50 hidden lg:block"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-24">
    <div class="text-center max-w-4xl mx-auto">

      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-blue-500/10 border border-blue-500/25 rounded-full px-5 py-2 mb-8 reveal shadow-lg shadow-blue-500/10">
        <span class="w-2 h-2 bg-blue-400 rounded-full animate-pulse"></span>
        <span class="text-blue-300 text-sm font-semibold">{t.hero.badge}</span>
      </div>

      <!-- Title -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black text-white mb-6 leading-[1.05] tracking-tight reveal reveal-delay-1">
        {t.hero.title}
        <span class="block bg-gradient-to-r from-blue-400 via-cyan-300 to-purple-400 bg-clip-text text-transparent text-glow mt-1">
          {t.hero.titleHighlight}
        </span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl text-slate-400 mb-10 max-w-2xl mx-auto leading-relaxed reveal reveal-delay-2">
        {t.hero.subtitle}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center reveal reveal-delay-3">
        <a href="#contact" class="btn-shimmer text-white px-9 py-4 rounded-xl font-black text-base shadow-2xl shadow-blue-500/30">
          📅 {t.hero.cta1}
        </a>
        <a href="https://wa.me/436766711940" target="_blank"
           class="bg-white/5 hover:bg-white/10 text-white px-9 py-4 rounded-xl font-black text-base border border-white/15 hover:border-green-500/40 transition-all hover:scale-105 hover:shadow-lg hover:shadow-green-500/10">
          💬 {t.hero.cta2}
        </a>
      </div>

      <!-- Stats -->
      <div class="flex flex-col sm:flex-row gap-10 justify-center mt-20 pt-10 border-t border-white/5 reveal reveal-delay-4">
        {[
          { val: '5-8', sub: lang==='es'?'días de entrega':lang==='en'?'days delivery':lang==='de'?'Tage Lieferzeit':lang==='pt'?'dias de entrega':'днів доставки' },
          { val: '12+', sub: lang==='es'?'servicios':lang==='en'?'services':lang==='de'?'Leistungen':lang==='pt'?'serviços':'послуг' },
          { val: '5',   sub: lang==='es'?'idiomas':lang==='en'?'languages':lang==='de'?'Sprachen':lang==='pt'?'idiomas':'мов' },
          { val: '24h', sub: lang==='es'?'respuesta':lang==='en'?'response':lang==='de'?'Antwortzeit':lang==='pt'?'resposta':'відповідь' },
        ].map(s => (
          <div class="text-center group cursor-default">
            <div class="text-4xl font-black text-white group-hover:text-transparent group-hover:bg-gradient-to-r group-hover:from-blue-400 group-hover:to-cyan-400 group-hover:bg-clip-text transition-all">{s.val}</div>
            <div class="text-slate-500 text-sm mt-1 font-medium">{s.sub}</div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>


<!-- ══════════ WAVE ══════════ -->
<div class="wave-divider -mt-1">
  <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0,35 C240,70 480,0 720,35 C960,70 1200,0 1440,35 L1440,70 L0,70 Z" fill="#0a0715"/>
  </svg>
</div>


<!-- ══════════ PROBLEM ══════════ -->
<section class="py-28 section-problem relative overflow-hidden">
  <div class="dot-pattern absolute inset-0 opacity-40"></div>
  <div class="blob w-[600px] h-[300px] bg-red-800/15 -top-20 left-1/2 -translate-x-1/2"></div>
  <div class="blob blob-2 w-[400px] h-[300px] bg-purple-800/10 bottom-0 right-0"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16 reveal">
      <span class="text-red-400 text-xs font-black uppercase tracking-widest">Pain points</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white mt-3 mb-4">{t.problem.title}</h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">{t.problem.subtitle}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {t.problem.items.map((item, i) => (
        <div class={`glow-card bg-[#0d0a18]/80 border border-red-900/20 rounded-2xl p-6 backdrop-blur-sm reveal reveal-delay-${(i%3)+1}`}>
          <div class="w-11 h-11 icon-red rounded-xl flex items-center justify-center mb-4 text-lg">⚠️</div>
          <h3 class="text-white font-bold mb-2">{item.title}</h3>
          <p class="text-slate-500 text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ══════════ WAVE ══════════ -->
<div class="wave-divider -mt-1">
  <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0,0 C360,70 1080,0 1440,50 L1440,70 L0,70 Z" fill="#05091e"/>
  </svg>
</div>


<!-- ══════════ SERVICES ══════════ -->
<section id="services" class="py-28 section-services relative overflow-hidden">
  <div class="grid-bg absolute inset-0 opacity-30"></div>
  <div class="blob w-[700px] h-[400px] bg-blue-600/12 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"></div>
  <div class="blob blob-2 w-[400px] h-[400px] bg-cyan-600/10 top-0 right-0"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16 reveal">
      <span class="text-blue-400 text-xs font-black uppercase tracking-widest">Servicios</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white mt-3 mb-4">{t.services.title}</h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">{t.services.subtitle}</p>
    </div>
    <!-- Featured AI image -->
    <div class="mb-12 reveal">
      <div class="relative rounded-3xl overflow-hidden max-h-64 border border-blue-500/15 shadow-2xl shadow-blue-500/10">
        <img
          src="https://images.pexels.com/photos/36040448/pexels-photo-36040448.jpeg?auto=compress&cs=tinysrgb&w=1920"
          alt="AI Technology"
          class="w-full h-64 object-cover opacity-70"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-[#05091e] via-transparent to-[#05091e]"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-[#05091e] via-transparent to-transparent"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="text-white/80 text-lg font-black uppercase tracking-widest text-glow">AI · Automation · Technology</span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {t.services.items.map((s, i) => (
        <div class={`glow-card bg-[#070d20]/80 border border-blue-900/20 rounded-2xl p-5 group backdrop-blur-sm reveal reveal-delay-${(i%4)+1}`}>
          <div class={`w-11 h-11 ${iconColors[i]} rounded-xl flex items-center justify-center mb-3 text-lg group-hover:scale-110 transition-transform`}>{s.icon}</div>
          <h3 class="text-white font-bold mb-1.5 text-sm leading-snug">{s.title}</h3>
          <p class="text-slate-500 text-xs leading-relaxed">{s.desc}</p>
          <div class="mt-3 h-0.5 bg-gradient-to-r from-blue-500/0 via-blue-500/60 to-blue-500/0 w-0 group-hover:w-full transition-all duration-500 rounded-full"></div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ══════════ WAVE ══════════ -->
<div class="wave-divider -mt-1">
  <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0,50 C480,0 960,70 1440,20 L1440,70 L0,70 Z" fill="#060720"/>
  </svg>
</div>


<!-- ══════════ HOW IT WORKS ══════════ -->
<section id="how" class="py-28 section-how relative overflow-hidden">
  <div class="dot-pattern absolute inset-0 opacity-30"></div>
  <div class="blob w-[500px] h-[500px] bg-indigo-600/12 top-1/2 left-0 -translate-y-1/2"></div>
  <div class="blob blob-3 w-[400px] h-[400px] bg-purple-600/10 top-0 right-1/4"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16 reveal">
      <span class="text-purple-400 text-xs font-black uppercase tracking-widest">Proceso</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white mt-3 mb-4">{t.howItWorks.title}</h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">{t.howItWorks.subtitle}</p>
    </div>
    <!-- AI image split -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 mb-14 items-center reveal">
      <div class="relative rounded-2xl overflow-hidden border border-indigo-500/15 shadow-2xl shadow-indigo-500/10">
        <img
          src="https://images.pexels.com/photos/8849295/pexels-photo-8849295.jpeg?auto=compress&cs=tinysrgb&w=900"
          alt="AI Intelligence"
          class="w-full h-72 object-cover opacity-75"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-transparent to-[#060720]/80"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-[#060720] via-transparent to-transparent"></div>
      </div>
      <div>
        <p class="text-slate-300 text-lg leading-relaxed mb-4">
          {t.howItWorks.subtitle}
        </p>
        <div class="flex items-center gap-3">
          <div class="w-10 h-0.5 bg-gradient-to-r from-blue-500 to-purple-500 rounded-full"></div>
          <span class="text-blue-400 text-sm font-bold uppercase tracking-wider">NexiaMC</span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {t.howItWorks.steps.map((step, i) => (
        <div class={`relative reveal reveal-delay-${i+1}`}>
          <div class="glow-card bg-[#08082a]/80 border border-indigo-900/25 rounded-2xl p-6 h-full group backdrop-blur-sm">
            <div class="text-7xl font-black bg-gradient-to-br from-blue-500/40 to-purple-500/20 bg-clip-text text-transparent mb-4 leading-none select-none">{step.number}</div>
            <h3 class="text-white font-black mb-3 text-base group-hover:text-blue-300 transition-colors">{step.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{step.desc}</p>
          </div>
          {i < 3 && (
            <div class="hidden lg:flex absolute -right-3 top-1/2 -translate-y-1/2 z-10 w-7 h-7 bg-gradient-to-r from-blue-600 to-purple-600 border border-blue-500/30 rounded-full items-center justify-center shadow-lg shadow-blue-500/20">
              <span class="text-white text-xs font-bold">→</span>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ══════════ WAVE ══════════ -->
<div class="wave-divider -mt-1">
  <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0,20 C360,70 1080,0 1440,50 L1440,70 L0,70 Z" fill="#030d12"/>
  </svg>
</div>


<!-- ══════════ NICHES ══════════ -->
<section class="py-28 section-niches relative overflow-hidden">
  <div class="blob w-[600px] h-[400px] bg-teal-600/12 top-1/2 right-0 translate-x-1/4 -translate-y-1/2"></div>
  <div class="blob blob-2 w-[400px] h-[300px] bg-cyan-600/10 bottom-0 left-1/4"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16 reveal">
      <span class="text-teal-400 text-xs font-black uppercase tracking-widest">Sectores</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white mt-3 mb-4">{t.niches.title}</h2>
      <p class="text-slate-400 text-lg">{t.niches.subtitle}</p>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
      {t.niches.items.map((niche, i) => (
        <div class={`glow-card bg-[#04101a]/80 border border-teal-900/20 rounded-2xl p-4 text-center group cursor-default backdrop-blur-sm reveal reveal-delay-${(i%3)+1}`}>
          <div class="text-3xl mb-2 group-hover:scale-130 transition-transform duration-300 inline-block">{niche.icon}</div>
          <div class="text-slate-400 text-xs font-semibold group-hover:text-teal-300 transition-colors">{niche.title}</div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ══════════ WAVE ══════════ -->
<div class="wave-divider -mt-1">
  <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0,50 C720,0 1080,70 1440,30 L1440,70 L0,70 Z" fill="#050818"/>
  </svg>
</div>


<!-- ══════════ PRICING ══════════ -->
<section id="pricing" class="py-28 section-pricing relative overflow-hidden">
  <div class="grid-bg absolute inset-0 opacity-20"></div>
  <div class="blob w-[700px] h-[400px] bg-blue-600/12 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"></div>
  <div class="blob blob-2 w-[400px] h-[300px] bg-purple-600/10 top-0 right-0"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16 reveal">
      <span class="text-blue-400 text-xs font-black uppercase tracking-widest">Inversión</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white mt-3 mb-4">{t.pricing.title}</h2>
      <p class="text-slate-400 text-lg">{t.pricing.subtitle}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">

      <!-- Project — featured -->
      <div class="reveal reveal-delay-1 gradient-border rounded-3xl">
        <div class="card-featured glow-card relative bg-gradient-to-br from-[#0d1a35] via-[#0b1428] to-[#0a1220] rounded-3xl p-8 overflow-hidden h-full">
          <div class="absolute top-0 right-0 w-56 h-56 bg-blue-500/15 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl pointer-events-none"></div>
          <div class="absolute bottom-0 left-0 w-40 h-40 bg-purple-500/10 rounded-full translate-y-1/2 -translate-x-1/2 blur-2xl pointer-events-none"></div>
          <div class="relative">
            <span class="inline-block bg-gradient-to-r from-blue-500/20 to-cyan-500/20 text-blue-300 text-xs font-black uppercase tracking-widest px-4 py-1.5 rounded-full mb-4 border border-blue-500/20">{t.pricing.project.label}</span>
            <div class="text-5xl font-black text-white mt-2 mb-1">{t.pricing.project.price}</div>
            <div class="text-slate-500 text-sm mb-2">{t.pricing.project.period}</div>
            <p class="text-slate-400 text-sm mb-6 leading-relaxed">{t.pricing.project.desc}</p>
            <ul class="space-y-3 mb-8">
              {t.pricing.project.features.map(f => (
                <li class="flex items-center gap-3 text-sm text-slate-300">
                  <span class="w-5 h-5 rounded-full icon-blue flex items-center justify-center text-white text-xs flex-shrink-0">✓</span>
                  {f}
                </li>
              ))}
            </ul>
            <a href="#contact" class="btn-shimmer block text-center text-white px-6 py-4 rounded-xl font-black shadow-xl shadow-blue-500/30">
              {t.pricing.project.cta}
            </a>
          </div>
        </div>
      </div>

      <!-- Maintenance -->
      <div class="reveal reveal-delay-2 glow-card bg-[#080b1a]/80 border border-cyan-900/20 rounded-3xl p-8 backdrop-blur-sm">
        <span class="inline-block bg-cyan-500/10 text-cyan-400 text-xs font-black uppercase tracking-widest px-4 py-1.5 rounded-full mb-4 border border-cyan-500/20">{t.pricing.maintenance.label}</span>
        <div class="text-5xl font-black text-white mt-2 mb-1">{t.pricing.maintenance.price}</div>
        <div class="text-slate-500 text-sm mb-2">{t.pricing.maintenance.period}</div>
        <p class="text-slate-400 text-sm mb-6 leading-relaxed">{t.pricing.maintenance.desc}</p>
        <ul class="space-y-3 mb-8">
          {t.pricing.maintenance.features.map(f => (
            <li class="flex items-center gap-3 text-sm text-slate-300">
              <span class="w-5 h-5 rounded-full icon-cyan flex items-center justify-center text-white text-xs flex-shrink-0">✓</span>
              {f}
            </li>
          ))}
        </ul>
