<script is:inline define:vars={{ problemDetails, serviceDetails }}>
  /* ── Scroll reveal ── */
  const obs = new IntersectionObserver(function(e) { e.forEach(function(x) { if (x.isIntersecting) x.target.classList.add('visible'); }); }, { threshold: 0.08 });
  document.querySelectorAll('.reveal').forEach(function(el) { obs.observe(el); });

  /* ── Problem cards accordion ── */
  document.querySelectorAll('.problem-card-expand').forEach(function(card) {
    const idx = parseInt(card.dataset.index || '0');
    const detail = card.querySelector('.expand-detail');
    const text = card.querySelector('.expand-text');
    const arrow = card.querySelector('.expand-arrow');
    if (text && problemDetails[idx]) text.textContent = problemDetails[idx];
    card.addEventListener('click', function() {
      const isOpen = card.classList.contains('expanded');
      document.querySelectorAll('.problem-card-expand.expanded').forEach(function(c) {
        c.classList.remove('expanded');
        const d = c.querySelector('.expand-detail');
        const a = c.querySelector('.expand-arrow');
        if (d) d.style.maxHeight = '0';
        if (a) a.style.transform = 'rotate(0deg)';
      });
      if (!isOpen && detail && arrow) {
        card.classList.add('expanded');
        detail.style.maxHeight = detail.scrollHeight + 'px';
        arrow.style.transform = 'rotate(180deg)';
      }
    });
  });

  /* ── Service cards accordion ── */
  document.querySelectorAll('.service-card-expand').forEach(function(card) {
    const idx = parseInt(card.dataset.index || '0');
    const detail = card.querySelector('.service-expand-detail');
    const text = card.querySelector('.service-expand-text');
    const arrow = card.querySelector('.service-expand-arrow');
    const line = card.querySelector('.service-line');
    if (text && serviceDetails[idx]) {
      text.innerHTML = serviceDetails[idx].split('\n').map(function(l) { return '<span class="block mb-1">' + l + '</span>'; }).join('');
    }
    card.addEventListener('click', function() {
      const isOpen = card.classList.contains('svc-expanded');
      document.querySelectorAll('.service-card-expand.svc-expanded').forEach(function(c) {
        c.classList.remove('svc-expanded');
        const d = c.querySelector('.service-expand-detail');
        const a = c.querySelector('.service-expand-arrow');
        const ln = c.querySelector('.service-line');
        if (d) d.style.maxHeight = '0';
        if (a) a.style.transform = 'rotate(0deg)';
        if (ln) ln.style.width = '0';
      });
      if (!isOpen && detail && arrow) {
        card.classList.add('svc-expanded');
        detail.style.maxHeight = detail.scrollHeight + 'px';
        arrow.style.transform = 'rotate(180deg)';
        if (line) line.style.width = '100%';
      }
    });
  });

  /* ── Particle canvas ── */
  const canvas = document.getElementById('particles');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    function resizeCanvas() { canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight; }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    const pts = Array.from({length: 75}, function() { return {
      x: Math.random() * canvas.width,
      y: Math.random() * canvas.height,
      vx: (Math.random() - 0.5) * 0.45,
      vy: (Math.random() - 0.5) * 0.45,
      r: Math.random() * 1.5 + 0.5,
    }; });

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (const p of pts) {
        p.x += p.vx; p.y += p.vy;
        if (p.x < 0 || p.x > canvas.width)  p.vx *= -1;
        if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(96,165,250,0.75)';
        ctx.fill();
      }
      for (let i = 0; i < pts.length; i++) {
        for (let j = i + 1; j < pts.length; j++) {
          const dx = pts[i].x - pts[j].x, dy = pts[i].y - pts[j].y;
          const d = Math.sqrt(dx*dx + dy*dy);
          if (d < 130) {
            ctx.beginPath();
            ctx.moveTo(pts[i].x, pts[i].y);
            ctx.lineTo(pts[j].x, pts[j].y);
            ctx.strokeStyle = 'rgba(59,130,246,' + (0.28*(1-d/130)) + ')';
            ctx.lineWidth = 0.7;
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(draw);
    }
    draw();
  }

  /* ── 3D card tilt ── */
  document.querySelectorAll('.glow-card').forEach(function(card) {
    card.addEventListener('mouseenter', function() { card.style.transition = 'transform 0.1s ease, box-shadow 0.3s ease, border-color 0.3s ease'; });
    card.addEventListener('mousemove', function(e) {
      const r = card.getBoundingClientRect();
      const x = (e.clientX - r.left) / r.width  - 0.5;
      const y = (e.clientY - r.top)  / r.height - 0.5;
      card.style.transform = 'perspective(900px) rotateX(' + (-y*7) + 'deg) rotateY(' + (x*7) + 'deg) translateZ(10px)';
    });
    card.addEventListener('mouseleave', function() {
      card.style.transition = 'transform 0.45s ease, box-shadow 0.3s ease, border-color 0.3s ease';
      card.style.transform  = 'perspective(900px) rotateX(0deg) rotateY(0deg) translateZ(0)';
    });
  });

  /* ── Form ── */
  const form = document.getElementById('contact-form');
  const ok   = document.getElementById('form-success');
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      if (ok) ok.classList.remove('hidden');
      form.reset();
      setTimeout(function() { if (ok) ok.classList.add('hidden'); }, 5000);
    });
  }
</script>

</Layout>
